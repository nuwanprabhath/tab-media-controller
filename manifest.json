{
  "manifest_version": 3,
  "name": "Tab Media Controller",
  "description": "Control media across tabs without switching to them. Play/pause, Picture-in-Picture, and autoplay playlist support.",
  "version": "1.0.0",
  "permissions": ["tabs", "scripting", "activeTab", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "toggle-media": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Alt+P"
      },
      "description": "Pause/Play media in the most recent audible tab"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
